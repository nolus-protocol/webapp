{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "balances": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "denom": {
            "type": "string"
          },
          "amount": {
            "type": "string",
            "pattern": "^-?(\\d+\\.?\\d*|\\.\\d+)$",
            "minLength": 1
          },
          "amount_usd": {
            "type": "string",
            "pattern": "^-?(\\d+\\.?\\d*|\\.\\d+)$",
            "minLength": 1
          },
          "decimal_digits": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "key",
          "symbol",
          "denom",
          "amount",
          "amount_usd",
          "decimal_digits"
        ],
        "additionalProperties": {}
      }
    },
    "total_value_usd": {
      "type": "string",
      "pattern": "^-?(\\d+\\.?\\d*|\\.\\d+)$",
      "minLength": 1
    }
  },
  "required": [
    "balances",
    "total_value_usd"
  ],
  "additionalProperties": {}
}
